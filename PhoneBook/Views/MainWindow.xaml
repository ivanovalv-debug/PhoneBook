<Window x:Class="PhoneBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга" 
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen" Background="HotPink">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="DeepPink" Margin="0,0,0,10">
            <Button Content="📋 Контакты" Command="{Binding ShowContactsCommand}" Margin="10,10,5,10" Padding="15,8" Background="HotPink" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="️ О программе" Command="{Binding ShowAboutCommand}" Margin="5,10,10,10" Padding="15,8" Background="HotPink" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
        <ContentControl Content="{Binding NavigationService.CurrentViewModel}" Margin="10"/>
    </DockPanel>
</Window>
